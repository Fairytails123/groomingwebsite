---
// Rolling-hill section divider — the countryside motif between section colours.
// Renders at the TOP of a section; `class` sets the section's bg colour via text-*.
interface Props {
  class?: string;
  flip?: boolean;
}
const { class: className = '', flip = false } = Astro.props;
---

<svg
  class:list={['pointer-events-none block w-full', className]}
  viewBox="0 0 1440 70"
  preserveAspectRatio="none"
  aria-hidden="true"
  style={`height: clamp(32px, 5vw, 70px); ${flip ? 'transform: scaleX(-1);' : ''}`}
>
  <path
    d="M0 70 L0 48 C240 8 420 4 720 28 C1020 52 1240 18 1440 38 L1440 70 Z"
    fill="currentColor"></path>
</svg>
