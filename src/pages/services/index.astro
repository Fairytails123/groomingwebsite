---
// Legacy URL preserved: /services/ . The hub of the services cluster.
// Source: grooming-image-archive/services/copy.md — the canonical page for
// add-on prices (owner ruling; /services-2/ was the stale duplicate and is now a
// redirect stub). Every price renders from pricing.json.
//
// The add-on photos are the old site's 300x300 originals — no larger version has
// ever existed — so they are used as small round thumbnails, where 300px is
// still crisp at 2x, rather than being blown up into hero images.
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import HillDivider from '../../components/HillDivider.astro';
import { business } from '../../data/business';
import pricing from '../../data/pricing.json';
import groupOfDogs from '../../assets/pages/services/group-of-dogs.png';
import brunoPoster from '../../assets/pages/services/brunos-groom-poster.jpg';
import bathAndBrush from '../../assets/pages/services/bath-and-brush.jpg';
import handStripping from '../../assets/pages/services/hand-stripping.jpg';
import teeth from '../../assets/pages/services/teeth.jpg';
import teethIntensive from '../../assets/pages/services/teeth-intensive.jpg';
import massage from '../../assets/pages/services/massage.jpg';
import mudBath from '../../assets/pages/services/mud-bath.jpg';
import nails from '../../assets/pages/services/nails.jpg';
import puppy from '../../assets/pages/services/puppy.jpg';
import matting from '../../assets/pages/services/matting.jpg';
import sensitiveDog from '../../assets/pages/services/sensitive-dog.jpg';
import additionalTime from '../../assets/pages/services/additional-time.jpg';
import pickupImg from '../../assets/pages/services/pickup.jpg';

const { addOns, extraCharges, subscription, pickup, fullGroom } = pricing;

// Photo + deep link per add-on, keyed by the name in pricing.json. Prices and
// notes come from the data — only presentation lives here.
const addOnMeta: Record<string, { image?: ImageMetadata; alt?: string; href?: string }> = {
  'Bath, Brush and Tidy': { image: bathAndBrush, alt: 'A small dog being bathed', href: '/services/full-groom-price-list/#bath-brush' },
  'Hand stripping': { image: handStripping, alt: 'A wire-coated terrier being hand stripped' },
  'Teeth cleaning': { image: teeth, alt: "A dog's teeth being cleaned", href: '/services/teeth-cleaning/' },
  'Intensive teeth cleaning': { image: teethIntensive, alt: 'A dog having an intensive teeth cleaning treatment', href: '/services/teeth-cleaning/' },
  'Doggy oil massage': { image: massage, alt: 'A dog having an oil massage', href: '/services/doggy-massage/' },
  'Mud bath': { image: mudBath, alt: 'A dog enjoying a mud bath treatment' },
  Nails: { image: nails, alt: "A dog's nails being clipped" },
  'Puppy introduction': { image: puppy, alt: 'A puppy meeting the grooming salon for the first time' },
  // Homeless dogs deliberately has NO image: the old site never had one for it,
  // and every other photo here already belongs to another card. Reusing one
  // (pickup.jpg was the temptation) just prints the same picture twice on the
  // same screen. The card reads fine without it, and it has its own page.
  'Homeless dogs': { href: '/services/homeless-dogs/' },
};

const extraMeta: Record<string, { image: ImageMetadata; alt: string }> = {
  'Matting — Level 1': { image: matting, alt: 'A matted coat being worked on' },
  'Sensitive dog': { image: sensitiveDog, alt: 'A groomer carefully handling a nervous dog' },
  'Additional time': { image: additionalTime, alt: 'A groomer taking extra time over a dog' },
};

// The three matting levels are one card with three tiers, not three cards.
const mattingLevels = extraCharges.filter((e) => e.name.startsWith('Matting'));
const otherExtras = extraCharges.filter((e) => !e.name.startsWith('Matting'));

const priceOf = (a: { price?: number; priceDisplay?: string }) =>
  a.priceDisplay ?? `£${a.price}`;
---

<Base
  title="Services - The Fairy Tails Dog Grooming"
  description="We offer professional and reliable services in dog grooming, each of them tailored to suit the dog's specific needs."
  path="/services/"
  ogImage={`${business.domain}${groupOfDogs.src}`}
>
  <article data-page="services">
    <header class="bg-moss-900 pb-16 pt-32 sm:pb-20 sm:pt-40">
      <div class="mx-auto max-w-3xl px-4">
        <p class="eyebrow text-honey-300">What we do</p>
        <h1 class="mt-4 font-display text-4xl font-bold leading-tight text-cream-50 sm:text-5xl">
          Our services
        </h1>
        <p class="mt-4 max-w-xl text-lg text-cream-200">
          Professional, reliable dog grooming — each service tailored to the dog in front of us. If
          what you need isn't here, just ask.
        </p>
      </div>
    </header>
    <HillDivider class="text-moss-900" flip />

    <!-- Full groom -->
    <section class="mx-auto max-w-6xl px-4 pb-6 pt-10 sm:pt-14">
      <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
          <p class="eyebrow text-honey-700">The main event</p>
          <h2 class="mt-3 font-display text-3xl font-bold text-moss-900">
            A full groom, tailored to your breed
          </h2>
          <p class="mt-4 leading-relaxed text-bark-700">
            Because all dogs are different, we've tailored our grooming to the needs of each
            individual breed. A full groom includes a wash, dry, cut, brush — and nails clipped if
            your dog allows it.
          </p>
          <p class="mt-4 font-display text-4xl font-bold text-moss-800">From £{fullGroom.from}</p>
          <div class="mt-6 flex flex-wrap gap-4">
            <a href="/services/full-groom-price-list/" class="btn btn-moss">Full groom price list</a>
            <a href="/services/haircut-lengths/" class="btn btn-ghost-light !border-moss-700/40 !text-moss-800">
              Haircut lengths guide
            </a>
          </div>
        </div>
        <figure class="polaroid">
          <Image
            src={groupOfDogs}
            alt="A group of freshly groomed dogs"
            widths={[600, 1200]}
            sizes="(min-width: 768px) 50vw, 100vw"
            loading="eager"
          />
        </figure>
      </div>
    </section>

    <!-- Subscription -->
    <section class="mx-auto max-w-6xl px-4 pt-16">
      <div class="rounded-3xl bg-moss-900 px-6 py-10 text-cream-50 sm:px-10 sm:py-12">
        <div class="grid gap-8 md:grid-cols-2 md:items-center">
          <div>
            <p class="eyebrow text-honey-300">Dog grooming subscription</p>
            <h2 class="mt-3 font-display text-3xl font-bold sm:text-4xl">
              £{subscription.price} a month, per dog
            </h2>
            <p class="mt-4 text-cream-200">{subscription.availability}</p>
            <div class="mt-7 flex flex-wrap items-center gap-4">
              <a href={business.subscription.stripeUrl} class="btn btn-honey">Sign up</a>
              <p class="text-sm text-cream-200">
                £{subscription.price} {subscription.unit}<br />
                {subscription.minTermMonths}-month minimum term
              </p>
            </div>
          </div>
          <ul class="grid gap-2.5 text-cream-100">
            {subscription.includes.map((i) => <li class="paw-bullet flex items-start text-sm">{i}</li>)}
          </ul>
        </div>
      </div>
    </section>

    <!-- Additional services -->
    <section id="additional-services" class="mx-auto max-w-6xl scroll-mt-24 px-4 pt-16">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow text-honey-700">Additional services</p>
        <h2 class="mt-3 font-display text-3xl font-bold text-moss-900">Add-ons and extras</h2>
        <p class="mt-4 leading-relaxed text-bark-700">
          Add any of these to a groom when you book. Pick ups and drop offs cover {pickup.eligible}
          — for everything else, please bring your dog to us.
        </p>
      </div>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {
          addOns.map((a) => {
            const meta = addOnMeta[a.name];
            return (
              <article class="flex gap-4 rounded-2xl border-2 border-cream-200 p-5">
                {meta?.image && (
                  <Image
                    src={meta.image}
                    alt={meta.alt ?? ''}
                    class="h-16 w-16 shrink-0 rounded-full object-cover"
                    widths={[64, 128]}
                    sizes="64px"
                    loading="lazy"
                  />
                )}
                <div class="min-w-0">
                  <h3 class="font-display text-lg font-bold leading-tight text-moss-900">{a.name}</h3>
                  <p class="mt-1 font-bold text-honey-700">{priceOf(a)}</p>
                  <p class="mt-2 text-sm leading-relaxed text-bark-600">{a.note}</p>
                  {/* min-h-11 = a 44px tap target (mobile gate, CLAUDE.md); mt drops
                      to 0 because centring the text in a 44px box supplies the gap. */}
                  {meta?.href && (
                    <a href={meta.href} class="inline-flex min-h-11 items-center text-sm font-bold text-moss-800 underline decoration-honey-500 underline-offset-4">
                      Find out more
                    </a>
                  )}
                </div>
              </article>
            );
          })
        }
      </div>
    </section>

    <!-- Additional charges -->
    <section class="mx-auto max-w-6xl px-4 pt-16">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow text-honey-700">If your dog needs it</p>
        <h2 class="mt-3 font-display text-3xl font-bold text-moss-900">Additional charges</h2>
        <p class="mt-4 leading-relaxed text-bark-700">
          We'd rather you saw these up front than found them on the bill. They cover the extra time
          and care some dogs need.
        </p>
      </div>

      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        <article class="flex gap-4 rounded-2xl border-2 border-cream-200 p-5">
          <Image
            src={extraMeta['Matting — Level 1'].image}
            alt={extraMeta['Matting — Level 1'].alt}
            class="h-16 w-16 shrink-0 rounded-full object-cover"
            widths={[64, 128]}
            sizes="64px"
            loading="lazy"
          />
          <div class="min-w-0">
            <h3 class="font-display text-lg font-bold leading-tight text-moss-900">Matting</h3>
            <p class="mt-1 font-bold text-honey-700">
              {mattingLevels.map((m) => `£${m.price}`).join(' · ')}
            </p>
            <p class="mt-2 text-sm leading-relaxed text-bark-600">
              We apply our dematting policy for matted coats — Level 1 £{mattingLevels[0].price} extra,
              Level 2 £{mattingLevels[1].price} extra, Level 3 £{mattingLevels[2].price} extra. Please see our
              <a href="/terms-and-conditions/" class="font-bold text-moss-800 underline decoration-honey-500 underline-offset-4">terms and conditions</a>.
            </p>
          </div>
        </article>

        {
          otherExtras.map((e) => {
            const meta = extraMeta[e.name];
            return (
              <article class="flex gap-4 rounded-2xl border-2 border-cream-200 p-5">
                {meta && (
                  <Image
                    src={meta.image}
                    alt={meta.alt}
                    class="h-16 w-16 shrink-0 rounded-full object-cover"
                    widths={[64, 128]}
                    sizes="64px"
                    loading="lazy"
                  />
                )}
                <div class="min-w-0">
                  <h3 class="font-display text-lg font-bold leading-tight text-moss-900">{e.name}</h3>
                  <p class="mt-1 font-bold text-honey-700">£{e.price}</p>
                  {e.note && <p class="mt-2 text-sm leading-relaxed text-bark-600">{e.note}</p>}
                </div>
              </article>
            );
          })
        }

        <article class="flex gap-4 rounded-2xl border-2 border-cream-200 p-5">
          <Image
            src={pickupImg}
            alt="A map of the Hastings area"
            class="h-16 w-16 shrink-0 rounded-full object-cover"
            widths={[64, 128]}
            sizes="64px"
            loading="lazy"
          />
          <div class="min-w-0">
            <h3 class="font-display text-lg font-bold leading-tight text-moss-900">Pick up &amp; drop off</h3>
            <p class="mt-1 font-bold text-honey-700">{pickup.priceDisplay}</p>
            <p class="mt-2 text-sm leading-relaxed text-bark-600">
              We collect your dog across {pickup.areas}, bring them to the salon and return them once
              they're done. Each leg is charged separately — £{pickup.roundTripPrice} for the round trip.
            </p>
          </div>
        </article>
      </div>
    </section>

    <!-- Homeless dogs -->
    <section class="mx-auto max-w-6xl px-4 pt-16">
      <div class="rounded-3xl bg-cream-100 px-6 py-10 text-center sm:px-10">
        <p class="eyebrow text-honey-700">For the love of dogs</p>
        <h2 class="mt-3 font-display text-3xl font-bold text-moss-900">Homeless dogs groom free</h2>
        <p class="mx-auto mt-4 max-w-lg leading-relaxed text-bark-700">
          We offer free dog grooming for homeless dogs — including pick up and drop-offs. Just
          mention "Homeless" when booking.
        </p>
        <a href="/services/homeless-dogs/" class="btn btn-moss mt-7">Find out more</a>
      </div>
    </section>

    <!-- Case study video -->
    <section class="mx-auto max-w-4xl px-4 pt-16">
      <div class="text-center">
        <p class="eyebrow text-honey-700">Case study</p>
        <h2 class="mt-3 font-display text-3xl font-bold text-moss-900">Bruno having his groom</h2>
        <p class="mx-auto mt-4 max-w-lg leading-relaxed text-bark-700">
          A short video of Bruno, start to finish — a typical groom at The Fairy Tails.
        </p>
      </div>
      {/* preload="none" is load-bearing: this file is ~20 MB and must never be
          fetched just because someone opened the page. The poster is a real frame
          from the video (scripts/video-poster.mjs), so there is something to see
          at t=0 without a byte of video being downloaded. */}
      <video
        class="mt-8 w-full rounded-3xl shadow-[var(--shadow-polaroid)]"
        controls
        preload="none"
        playsinline
        poster={brunoPoster.src}
        width="1280"
        height="720"
      >
        <source src="/media/brunos-groom.mp4" type="video/mp4" />
        Your browser can't play this video — it shows Bruno the Basset Hound being bathed, dried and
        groomed at our salon.
      </video>
    </section>

    <!-- FAQs + T&Cs -->
    <section class="mx-auto max-w-3xl px-4 pb-24 pt-16 text-center">
      <h2 class="font-display text-3xl font-bold text-moss-900">Questions before you book?</h2>
      <p class="mx-auto mt-4 max-w-lg leading-relaxed text-bark-700">
        We know how important your dog is to you, and that you may have a lot to ask before booking
        a groom. We've answered the most common ones — and if yours isn't there, just ask us.
      </p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-4">
        <a href="/services/frequently-asked-questions/" class="btn btn-moss">Read the FAQs</a>
        <a href={business.booking.jotform} class="btn btn-honey">Book Appointment</a>
      </div>
      <p class="mt-8 text-sm text-bark-500">
        You can also
        <a href="/terms-and-conditions/" class="font-bold text-moss-800 underline decoration-honey-500 underline-offset-4">view our terms and conditions</a>.
      </p>
    </section>
  </article>
</Base>
