---
// Legacy URL preserved: /services/full-groom-price-list/ .
// Every price comes from src/data/pricing.json (generated by `npm run
// extract-prices` from the harvested WordPress tables — never hand-typed).
// Source of copy: grooming-image-archive/services__full-groom-price-list/copy.md.
//
// DELIBERATE STRUCTURAL CHANGE (logged in WEBSITE-PLAN.md): the old page
// interleaved the bath/brush and subscription blocks BETWEEN the three breed
// tables. Here the three tables are contiguous so the breed filter operates on
// one uninterrupted run of rows; the two blocks follow. No facts moved.
import Base from '../../layouts/Base.astro';
import HillDivider from '../../components/HillDivider.astro';
import PriceTable from '../../components/PriceTable.astro';
import { business } from '../../data/business';
import pricing from '../../data/pricing.json';

const { fullGroom, bathBrushTidy, subscription, pickup, _meta } = pricing;
const totalRows = fullGroom.breeds.length + fullGroom.crossbreeds.length + fullGroom.deShed.length;
---

<Base
  title="Dog grooming price list - The Fairy Tails Dog Grooming"
  description="We tailor our grooming service to meet the demands of individual dogs, so we have devised a price list that ensures fair pricing for each client."
  path="/services/full-groom-price-list/"
>
  <article data-page="price-list">
    <header class="bg-moss-900 pb-16 pt-32 sm:pb-20 sm:pt-40">
      <div class="mx-auto max-w-3xl px-4">
        <p class="eyebrow text-honey-300">Full grooms</p>
        <h1 class="mt-4 font-display text-4xl font-bold leading-tight text-cream-50 sm:text-5xl">
          Price list
        </h1>
        <p class="mt-4 max-w-xl text-lg text-cream-200">
          {totalRows} breeds, priced individually — because a Newfoundland is not a Pug. Full grooms
          start at £{fullGroom.from}.
        </p>
      </div>
    </header>
    <HillDivider class="text-moss-900" flip />

    <div class="mx-auto max-w-3xl px-4 pb-24 pt-10 sm:pt-14">
      <ul class="space-y-2 text-sm text-bark-600">
        {_meta.disclaimers.map((d) => <li class="paw-bullet">{d}</li>)}
        <li class="paw-bullet">Breeds that need a de-shed are in their own table below.</li>
      </ul>

      {/* Filter UI ships hidden and is revealed by the script below. With no JS
          it would be a dead input — and every row is already on the page, so
          nobody loses anything by not seeing it. */}
      <div class="mt-8 rounded-2xl bg-cream-100 p-4 sm:p-5" data-filter-ui hidden>
        <label class="field-label" for="breed-filter">Find your breed</label>
        <div class="relative">
          <input
            type="search"
            id="breed-filter"
            class="field pl-11"
            placeholder="Start typing — e.g. Cockerpoo"
            autocomplete="off"
          />
          <svg
            class="pointer-events-none absolute left-4 top-1/2 h-4 w-4 -translate-y-1/2 text-bark-400"
            viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            stroke-linecap="round" aria-hidden="true"
          >
            <circle cx="11" cy="11" r="7"></circle><path d="m20 20-3.5-3.5"></path>
          </svg>
        </div>
        <p class="mt-2 text-sm text-bark-500" data-filter-status role="status" aria-live="polite"></p>
      </div>

      <div data-tables>
        <PriceTable
          id="breeds"
          heading="Breeds"
          colLabel="Breed – full groom"
          rows={fullGroom.breeds}
        >
          <p slot="intro" class="mt-3 text-bark-700">
            Find your breed (or the closest match) in the alphabetical list below.
          </p>
        </PriceTable>

        <PriceTable
          id="crossbreeds"
          heading="Popular crossbreeds"
          colLabel="Crossbreed – full groom"
          rows={fullGroom.crossbreeds}
        >
          <p slot="intro" class="mt-3 text-bark-700">Full grooms for the crosses we see most often.</p>
        </PriceTable>

        <PriceTable
          id="de-shed"
          heading="De-shed breeds"
          colLabel="De-shed breed – full groom"
          rows={fullGroom.deShed}
        >
          <p slot="intro" class="mt-3 text-bark-700">{fullGroom.deShedNote}</p>
        </PriceTable>
      </div>

      <p class="mt-6 hidden text-bark-700" data-no-results>
        No breed matches that search. If your dog is a cross or mix, try the breed they resemble the
        most — or <a href="/contact/" class="font-bold text-moss-800 underline decoration-honey-500 underline-offset-4">ask us</a> and we'll price it for you.
      </p>

      <!-- Bath, brush and tidy -->
      <section id="bath-brush" class="scroll-mt-24 pt-14">
        <h2 class="font-display text-2xl font-bold text-moss-900 sm:text-3xl">Bath, brush and tidy</h2>
        <p class="mt-3 text-bark-700">
          Any breed above can come in for a bath, brush and tidy instead of a full groom. It's priced
          on size, not breed.
        </p>
        <table class="mt-5 w-full border-collapse text-left">
          <caption class="sr-only">Bath, brush and tidy prices by size of dog</caption>
          <thead>
            <tr class="border-b-2 border-moss-200">
              <th scope="col" class="py-2.5 pr-3 text-sm font-bold text-bark-700">Size of dog</th>
              <th scope="col" class="py-2.5 pl-3 text-right text-sm font-bold text-bark-700">Price</th>
            </tr>
          </thead>
          <tbody>
            {
              bathBrushTidy.sizes.map((s) => (
                <tr class="border-b border-cream-200">
                  <td class="py-2.5 pr-3 text-bark-700">{s.name}</td>
                  <td class="py-2.5 pl-3 text-right font-bold tabular-nums text-moss-800">£{s.price}</td>
                </tr>
              ))
            }
          </tbody>
        </table>
        <p class="mt-4 rounded-xl bg-cream-100 px-4 py-3 text-sm text-bark-600">
          <strong>Please note:</strong> {bathBrushTidy.note}
        </p>
      </section>

      <!-- Subscription -->
      <section id="subscription" class="scroll-mt-24 pt-14">
        <div class="rounded-3xl bg-moss-900 px-6 py-10 text-cream-50 sm:px-10">
          <p class="eyebrow text-honey-300">Dog grooming subscription</p>
          <h2 class="mt-3 font-display text-3xl font-bold">
            £{subscription.price} a month, per dog
          </h2>
          <p class="mt-3 text-cream-200">{subscription.availability}</p>
          <ul class="mt-6 grid gap-2.5 text-cream-100 sm:grid-cols-2">
            {subscription.includes.map((i) => <li class="paw-bullet flex items-start text-sm">{i}</li>)}
          </ul>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a href={business.subscription.stripeUrl} class="btn btn-honey">Sign up</a>
            <p class="text-sm text-cream-200">
              £{subscription.price} {subscription.unit} · {subscription.minTermMonths}-month minimum term
            </p>
          </div>
        </div>
      </section>

      <!-- Pick up & drop off -->
      <section class="pt-14">
        <div class="rounded-2xl border-2 border-cream-200 px-5 py-6">
          <h2 class="font-display text-xl font-bold text-moss-900">Pick up &amp; drop off</h2>
          <p class="mt-2 text-bark-700">{pickup.note}</p>
        </div>
      </section>

      <section class="pt-14 text-center">
        <h2 class="font-display text-2xl font-bold text-moss-900">Unsure of your price?</h2>
        <p class="mx-auto mt-3 max-w-md text-bark-700">
          No problem — call us on
          <a href={business.phones.main.tel} class="font-bold text-moss-800 underline decoration-honey-500 underline-offset-4">{business.phones.main.display}</a>
          or send us a message and we'll work it out with you.
        </p>
        <div class="mt-7 flex flex-wrap items-center justify-center gap-4">
          <a href={business.booking.jotform} class="btn btn-honey">Book Appointment</a>
          <a href="/contact/" class="btn btn-moss">Ask us a question</a>
        </div>
      </section>
    </div>
  </article>
</Base>

<script>
  function initBreedFilter() {
    const ui = document.querySelector('[data-filter-ui]') as HTMLElement | null;
    const input = document.getElementById('breed-filter') as HTMLInputElement | null;
    const tables = document.querySelector('[data-tables]') as HTMLElement | null;
    if (!ui || !input || !tables || ui.dataset.init) return;
    ui.dataset.init = '1';

    const status = document.querySelector('[data-filter-status]') as HTMLElement;
    const noResults = document.querySelector('[data-no-results]') as HTMLElement;
    const sections = [...tables.querySelectorAll('[data-price-section]')] as HTMLElement[];
    const rows = [...tables.querySelectorAll('[data-row]')] as HTMLElement[];
    const total = rows.length;

    // The input only exists for people who have JS — reveal it now.
    ui.hidden = false;

    const fold = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');

    const apply = () => {
      const q = fold(input.value.trim());
      const filtering = q.length > 0;
      let shown = 0;

      for (const section of sections) {
        const table = section.querySelector('table') as HTMLElement;
        const empty = section.querySelector('[data-empty]') as HTMLElement;
        const secRows = [...section.querySelectorAll('[data-row]')] as HTMLElement[];
        let visible = 0;

        for (const row of secRows) {
          const hit = !filtering || (row.dataset.name || '').includes(q);
          row.hidden = !hit;
          // Re-stripe as we go: :nth-child would count the hidden rows too.
          row.classList.toggle('is-odd', hit && visible % 2 === 0);
          if (hit) visible++;
        }

        table.toggleAttribute('data-filtered', filtering);
        empty.hidden = visible > 0;
        // Keep the heading visible while filtering so the count reads in context;
        // hide the whole section only when nothing at all matches anywhere.
        section.hidden = filtering && visible === 0;
        shown += visible;
      }

      noResults.classList.toggle('hidden', !(filtering && shown === 0));
      status.textContent = filtering
        ? `${shown} of ${total} breeds match "${input.value.trim()}"`
        : `Showing all ${total} breeds.`;
    };

    apply();
    input.addEventListener('input', apply);
    input.addEventListener('search', apply); // the little (x) in a type=search
  }

  initBreedFilter();
  document.addEventListener('astro:page-load', initBreedFilter);
</script>
