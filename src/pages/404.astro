---
import Base from '../layouts/Base.astro';
import { business } from '../data/business';

// GitHub Pages serves dist/404.html with a real 404 status for any unmatched
// path (old WP query permalinks, /feed/ variants, probe traffic).
---

<Base
  title="Page not found - The Fairy Tails Dog Grooming"
  description="That page doesn't exist — but the dogs are still getting groomed. Find services, prices and booking here."
  path="/404/"
>
  <section class="mx-auto flex min-h-[70vh] max-w-3xl flex-col items-center justify-center px-4 pt-28 text-center">
    <p class="eyebrow text-honey-700">Woof — 404</p>
    <h1 class="mt-4 font-display text-4xl font-bold text-moss-900 sm:text-5xl">
      This page has wandered off
    </h1>
    <p class="mt-5 max-w-xl text-lg text-bark-700">
      The page you're after doesn't exist (or has been moved). Try one of these
      instead:
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-4">
      <a href={business.booking.jotform} class="btn btn-honey">Book an appointment</a>
      <a href="/services/" class="btn btn-moss">Our services</a>
      <a href="/contact/" class="btn btn-ghost-light !text-moss-800">Contact us</a>
    </div>
  </section>
</Base>
