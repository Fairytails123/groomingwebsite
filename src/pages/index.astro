---
import Base from '../layouts/Base.astro';

// STAGE-1 STUB — the homepage is built LAST in the inside-out order
// (WEBSITE-PLAN.md). Title/description are the harvested Yoast values so the
// head is production-correct from day one; the body is a placeholder that
// only ever appears on the noindexed preview.
//
// ⚠️ PICK-UP IS NOT FREE (owner ruling 2026-07-16: £2 per journey, see
// pricing.json `pickup`). The harvested Yoast description ended "With free door
// to door service in the Hastings area!" and the old homepage had a whole
// "Door-to-door service … at no extra cost" section. Neither may be carried
// over when this page is built for real in Stage 5.
---

<Base
  title="Home - The Fairy Tails Dog Grooming"
  description="Your friendly Hastings dog groomers that care for your dog as you would yourself. Full grooms tailored to your dog's breed, from £25, in the heart of Hastings."
  path="/"
>
  <section class="mx-auto flex min-h-[70vh] max-w-3xl flex-col items-center justify-center px-4 pt-28 text-center">
    <p class="eyebrow text-honey-700">The Fairy Tails Dog Grooming</p>
    <h1 class="mt-4 font-display text-4xl font-bold text-moss-900 sm:text-5xl">
      A brand-new website is on its way
    </h1>
    <p class="mt-5 max-w-xl text-lg text-bark-700">
      This is the build preview. The homepage ships last — every other page is
      being rebuilt first, then this one ties them all together.
    </p>
  </section>
</Base>
